# API
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Cloudinary — image uploads
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Google Maps / Places API key (enable Places API in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth (Phase 9)
# Create credentials at https://console.cloud.google.com/apis/credentials
# iOS: OAuth 2.0 client → iOS → bundle ID: com.travelog.app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
# Android: OAuth 2.0 client → Android → package: com.travelog.app
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
# Web: OAuth 2.0 client → Web → used as fallback and for Expo Go
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
